(3. SERVER START SEQUENCE) Tj
T*
() Tj
T*
(User) Tj
T*
(  -> ./build/bin/sqlapi_server --host ... --port ...) Tj
T*
() Tj
T*
(sqlapi_server_main.c) Tj
T*
(  -> sqlapi_server_config_set_defaults\(\)) Tj
T*
(  -> parse argv) Tj
T*
(  -> sqlapi_server_create\(server.c\)) Tj
T*
() Tj
T*
(server.c create stage) Tj
T*
(  -> validate config) Tj
T*
(  -> init state_mutex) Tj
T*
(  -> init task queue) Tj
T*
(  -> init table index registry) Tj
T*
(  -> init engine lock manager) Tj
T*
(  -> connect DbService adapter config) Tj
T*
() Tj
T*
(sqlapi_server_main.c) Tj
T*
(  -> sqlapi_server_start\(server.c\)) Tj
T*
() Tj
T*
(server.c start stage) Tj
T*
(  -> network init) Tj
T*
(  -> open listen socket) Tj
T*
(  -> start worker pool) Tj
T*
(  -> create accept thread) Tj
T*
() Tj
T*
(sqlapi_server_main.c) Tj
T*
(  -> sqlapi_server_wait\(server.c\)) Tj
T*
(  -> wait until accept thread and workers stop) Tj
T*
() Tj
T*
(4. GET /health SEQUENCE) Tj
T*
() Tj
T*
(Client -> accept thread -> task queue -> worker thread) Tj
T*
(worker thread -> http_read_request\(\) -> router.c) Tj
T*
(router.c -> api_handle_health\(health_handler.c\)) Tj
T*
(health_handler.c -> build JSON with worker_count and queue_depth) Tj
T*
(worker thread -> http_response_send\(\) -> close socket) Tj
ET
