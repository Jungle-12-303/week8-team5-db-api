(6. student INSERT LOCK FLOW) Tj
T*
() Tj
T*
(accept thread) Tj
T*
(  -> queue mutex lock) Tj
T*
(  -> push request to queue) Tj
T*
(  -> queue mutex unlock) Tj
T*
() Tj
T*
(worker thread) Tj
T*
(  -> queue mutex lock) Tj
T*
(  -> pop request from queue) Tj
T*
(  -> queue mutex unlock) Tj
T*
() Tj
T*
(sql_engine_adapter.c) Tj
T*
(  -> detect table name: student) Tj
T*
(  -> ask engine_lock_manager for student mutex) Tj
T*
() Tj
T*
(engine_lock_manager.c) Tj
T*
(  -> manager mutex lock) Tj
T*
(  -> find/create student entry) Tj
T*
(  -> manager mutex unlock) Tj
T*
(  -> student table mutex lock) Tj
T*
() Tj
T*
(sql_engine_adapter.c) Tj
T*
(  -> execute INSERT safely) Tj
T*
(  -> release student table mutex) Tj
